{
  "name": "liveinportmoody.com",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepare:hero-images": "node scripts/prepare-hero-images.mjs",
    "typecheck": "tsc --noEmit",
    "check:secrets": "grep -rn 'GHL_API_TOKEN=\\|access_token=\\|api_key=\\|NEXT_PUBLIC_.*TOKEN\\|NEXT_PUBLIC_.*SECRET\\|NEXT_PUBLIC_.*KEY' --include='*.ts' --include='*.tsx' --include='*.js' src/ | grep -v node_modules || echo 'No secret patterns found in source files'",
    "deploy:check": "npm run lint && npm run build",
    "deploy:prod": "npm run lint && npm run build && vercel deploy --prod --force",
    "smoke:prelaunch": "node scripts/prelaunch-smoke.mjs",
    "smoke:prelaunch:prod": "LIPM_BASE_URL=https://www.liveinportmoody.com node scripts/prelaunch-smoke.mjs",
    "crawl:prelaunch": "node scripts/prelaunch-crawl.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1041.0",
    "@hookform/resolvers": "^3.10.0",
    "@tailwindcss/typography": "^0.5.19",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.16.0",
    "maplibre-gl": "^5.24.0",
    "next": "^15.5.18",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.56.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
