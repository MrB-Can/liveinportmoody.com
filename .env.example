# =============================================================
# LiveInPortMoody.com — Environment Variable Reference
# =============================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local — it is gitignored.
# Production values live in Vercel Project Environment Variables.
# =============================================================

# --- Site identity (public — baked into build, visible in browser) ---
NEXT_PUBLIC_SITE_URL=https://liveinportmoody.com
NEXT_PUBLIC_PUBLIC_EMAIL=
NEXT_PUBLIC_PUBLIC_PHONE=
NEXT_PUBLIC_BROKERAGE_NAME=
NEXT_PUBLIC_BROKERAGE_ADDRESS=

# --- Analytics (public — baked into build, visible in browser) ---
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_CLARITY_ID=

# --- Feature flags (server-only — not NEXT_PUBLIC_) ---
COMING_SOON_ENABLED=false
PREVIEW_KEY=

# --- Interactive maps (public — baked into build, visible in browser) ---
# Production values: set in Vercel Project Environment Variables.
# .env.local must match Vercel values before running vercel deploy.
# If maps show "Map unavailable" after a deploy, stale false here is the most common cause.
NEXT_PUBLIC_INTERACTIVE_MAPS_ENABLED=false
# Map provider: "mapbox" (requires NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN) or "maplibre" (requires NEXT_PUBLIC_MAP_STYLE_URL)
NEXT_PUBLIC_MAP_PROVIDER=maplibre
# MapLibre style URL (required if NEXT_PUBLIC_MAP_PROVIDER=maplibre)
NEXT_PUBLIC_MAP_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
# Mapbox access token (required only if NEXT_PUBLIC_MAP_PROVIDER=mapbox — leave empty for maplibre)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# --- CRM — GoHighLevel (SERVER-ONLY — never prefix with NEXT_PUBLIC_) ---
# Default is "mock" for local dev. Use "ghl" only after real GHL IDs and fields are confirmed.
CRM_MODE=mock
GHL_LOCATION_ID=
GHL_PIPELINE_ID=
GHL_STAGE_ID=
GHL_PIPELINE_NAME=Warm Lead Nurture
GHL_STAGE_NAME=New Lead
GHL_OWNER_BUYER_USER_ID=
GHL_OWNER_SELLER_USER_ID=

# --- CRM API token — LOCAL DEV FALLBACK ONLY (SERVER-ONLY — never prefix with NEXT_PUBLIC_) ---
# In production, the token is retrieved from AWS Secrets Manager (see GHL_API_TOKEN_SECRET_ID below).
# For local dev only: set this directly if you are not using AWS Secrets Manager locally.
# Do NOT commit a real token here.
GHL_API_TOKEN=
# Alias supported for compatibility with the existing inbound-lead-connector project.
GHL_API_KEY=

# --- AWS Secrets Manager (SERVER-ONLY) ---
# Production: GHL_API_TOKEN is stored in AWS Secrets Manager, not as a plain env var.
# GHL_API_TOKEN_SECRET_ID and GHL_API_TOKEN_SECRET_KEY tell the adapter where to fetch it.
AWS_REGION=us-west-2
GHL_API_TOKEN_SECRET_ID=
GHL_API_TOKEN_SECRET_KEY=
