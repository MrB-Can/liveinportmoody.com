NEXT_PUBLIC_SITE_URL=https://liveinportmoody.com
NEXT_PUBLIC_PUBLIC_EMAIL=
# Current Phase 1 fallback can be a GHL number. Swap to CallRail later if adopted.
NEXT_PUBLIC_PUBLIC_PHONE=
NEXT_PUBLIC_BROKERAGE_NAME=
NEXT_PUBLIC_BROKERAGE_ADDRESS=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_CLARITY_ID=
COMING_SOON_ENABLED=true

# Default is mock. Use "ghl" only after real GHL IDs and fields are confirmed.
CRM_MODE=mock
GHL_LOCATION_ID=
GHL_PIPELINE_ID=
GHL_STAGE_ID=
GHL_PIPELINE_NAME=Warm Lead Nurture
GHL_STAGE_NAME=New Lead
GHL_OWNER_BUYER_USER_ID=
GHL_OWNER_SELLER_USER_ID=
GHL_OWNER_DEFAULT_USER_ID=

# Prefer AWS Secrets Manager for production.
GHL_API_TOKEN_SECRET_ID=
GHL_API_TOKEN_SECRET_KEY=
AWS_REGION=us-west-2

# Local development fallback only. Do not commit real values.
GHL_API_TOKEN=
# Alias supported for compatibility with the existing inbound-lead-connector project.
GHL_API_KEY=

# Interactive maps (Sprint 17: Live Maps Phase 1)
# Set to "true" to enable MapLibre GL on 5 routes (neighbourhoods, heritage-mountain, complexes, treetops, buildings)
# Maps only render when both ENABLED=true AND provider token/URL is set. Build always passes with default false.
NEXT_PUBLIC_INTERACTIVE_MAPS_ENABLED=false

# Map provider: "mapbox" (requires NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN) or "maplibre" (requires NEXT_PUBLIC_MAP_STYLE_URL)
NEXT_PUBLIC_MAP_PROVIDER=mapbox

# Mapbox access token (required if NEXT_PUBLIC_MAP_PROVIDER=mapbox)
# Generates style URL: https://api.mapbox.com/styles/v1/mapbox/streets-v12?access_token=<token>
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# MapLibre style URL (required if NEXT_PUBLIC_MAP_PROVIDER=maplibre)
# Example: https://tiles.stadiamaps.com/styles/stamen_terrain.json
NEXT_PUBLIC_MAP_STYLE_URL=
