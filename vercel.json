{
  "env": [
    {
      "key": "NEXT_PUBLIC_SITE_URL",
      "description": "The site URL",
      "value": "https://liveinportmoody.com"
    },
    {
      "key": "NEXT_PUBLIC_PUBLIC_EMAIL",
      "description": "Public contact email",
      "value": "@NEXT_PUBLIC_PUBLIC_EMAIL@"
    },
    {
      "key": "NEXT_PUBLIC_PUBLIC_PHONE",
      "description": "Public phone number",
      "value": "@NEXT_PUBLIC_PUBLIC_PHONE@"
    },
    {
      "key": "NEXT_PUBLIC_BROKERAGE_NAME",
      "description": "Brokerage name",
      "value": "@NEXT_PUBLIC_BROKERAGE_NAME@"
    },
    {
      "key": "NEXT_PUBLIC_BROKERAGE_ADDRESS",
      "description": "Brokerage address",
      "value": "@NEXT_PUBLIC_BROKERAGE_ADDRESS@"
    },
    {
      "key": "NEXT_PUBLIC_GA4_ID",
      "description": "Google Analytics 4 ID",
      "value": "@NEXT_PUBLIC_GA4_ID@"
    },
    {
      "key": "NEXT_PUBLIC_CLARITY_ID",
      "description": "Microsoft Clarity ID",
      "value": "@NEXT_PUBLIC_CLARITY_ID@"
    },
    {
      "key": "CRM_MODE",
      "description": "CRM adapter mode: 'mock' or 'ghl'",
      "value": "mock"
    }
  ],
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm ci"
}
